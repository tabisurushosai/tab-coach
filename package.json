{
  "name": "tab-coach",
  "version": "1.0.0",
  "private": true,
  "description": "Visualize tab overload and one-click cleanup. Fully offline Chrome extension.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "lint": "tsc --noEmit && eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.{ts,html,css}\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "zip": "bash build_zip.sh"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@types/node": "^25.8.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
